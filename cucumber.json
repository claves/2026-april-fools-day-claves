{
  "default": {
    "paths": ["specs/**/*.feature"],
    "require": ["tests/steps/**/*.ts", "tests/support/**/*.ts"],
    "requireModule": ["tsx"],
    "format": [
      "progress-bar",
      "html:output/cucumber-report.html"
    ],
    "formatOptions": {
      "snippetInterface": "async-await"
    },
    "language": "en"
  }
}
